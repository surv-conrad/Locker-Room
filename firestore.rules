rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isUser(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function isSuperAdmin() {
      return isAuthenticated() && 
        (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData(request.auth.uid).role == 'super_admin') ||
          (request.auth.token.email == "conradenock@gmail.com" && request.auth.token.email_verified == true)
        );
    }

    function isAdmin() {
      return isSuperAdmin() || (isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData(request.auth.uid).role == 'admin');
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // 1. Users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      
      // Users can create their own profile as 'viewer'
      allow create: if isUser(userId) && request.resource.data.role == 'viewer';
      
      // Only Super Admin can delete users
      allow delete: if isSuperAdmin();
      
      // Super Admin can update anything. 
      // Admins can update other users (except role).
      // Users can update their own profile (except role).
      allow update: if isSuperAdmin() || 
                    (isAdmin() && request.resource.data.role == resource.data.role) ||
                    (isUser(userId) && request.resource.data.role == resource.data.role);

      // 2. Tournament data (subcollections)
      match /auditLogs/{logId} {
        allow read: if isUser(userId) || isAdmin();
        allow create: if isUser(userId) || isAdmin();
        allow update: if false;
        allow delete: if false;
      }

      match /{subcollection}/{document=**} {
        allow read: if isAuthenticated();
        // Admins and Super Admins can manage any tournament data
        // Users can manage their own tournament data
        allow write: if isSuperAdmin() || isAdmin() || isUser(userId);
      }
    }

    // 3. Public tournaments
    match /public_tournaments/{tournamentId} {
      allow read: if true; // Publicly readable
      allow write: if isSuperAdmin() || isAdmin() || isUser(tournamentId);
    }

    // 4. Global catch-all
    match /{document=**} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin() || isAdmin();
    }
  }
}
